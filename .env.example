APP_NAME="Solo Roadside"
APP_ENV=local
APP_URL=http://127.0.0.1:8000

# Local development defaults to SQLite when DB_DSN is omitted.
# For MySQL, use:
# DB_DSN="mysql:host=127.0.0.1;port=3306;dbname=solo_roadside;charset=utf8mb4"
# DB_USER=root
# DB_PASS=

# Document Intake AI extraction (OpenAI).
# Leave OPENAI_API_KEY blank to disable AI extraction; uploads will still be
# stored but won't be classified until reprocessed after the key is added.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_DOCUMENT_EXTRACTION_ENABLED=true

# Outbound mail (used by the "Forgot password?" flow).
#   MAIL_DRIVER=log   writes each message to storage/sent-mail/*.eml.
#                     Safe default for local development — no real email is sent.
#   MAIL_DRIVER=mail  hands off to PHP's mail() — requires a working
#                     sendmail / SMTP relay configured in php.ini. Typically
#                     works on SiteGround; usually does NOT work on Windows.
#   MAIL_DRIVER=smtp  speaks SMTP directly to a remote server. No external
#                     dependencies. Configure SMTP_* below.
MAIL_DRIVER=log
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME="Solo Roadside"

# SMTP settings — only used when MAIL_DRIVER=smtp.
# Example for Gmail / Google Workspace (requires an App Password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=you@gmail.com
#   SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
#   SMTP_ENCRYPTION=tls
# Example for SiteGround:
#   SMTP_HOST=mail.wkrllc.com
#   SMTP_PORT=465
#   SMTP_USERNAME=no-reply@wkrllc.com
#   SMTP_PASSWORD=...
#   SMTP_ENCRYPTION=ssl
# Example for Mailtrap / Mailpit (dev catchers):
#   SMTP_HOST=sandbox.smtp.mailtrap.io
#   SMTP_PORT=2525
#   SMTP_USERNAME=...
#   SMTP_PASSWORD=...
#   SMTP_ENCRYPTION=tls
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_TIMEOUT=15

